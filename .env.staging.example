# Backend staging environment
# Use this file as reference to configure Vercel Preview/Branch env vars.

# Mercado Pago (TEST credentials only in staging)
MERCADO_PAGO_ACCESS_TOKEN="APP_USR_TEST-..."

# Public URLs for staging deployments
FRONTEND_URL="https://lunaperla-staging.vercel.app"
BACKEND_URL="https://lunaperla-backend-staging.vercel.app"

# Supabase STAGING project
SUPABASE_URL="https://YOUR_STAGING_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_STAGING_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_STAGING_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="products"

# Optional email provider in staging
RESEND_API_KEY="re_..."

# Admin auth (must be different from production)
JWT_SECRET="change-me-long-random-staging-secret"
JWT_EXPIRES_IN="12h"
ADMIN_USERNAME="admin_staging"
ADMIN_PASSWORD="change-me"

# Runtime
PORT="3001"
